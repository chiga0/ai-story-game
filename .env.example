# ===========================================
# AI 模型配置（必填）
# ===========================================

# 百炼平台 GLM-5 配置
# 获取地址：https://bailian.console.aliyun.com/
# API Key 用于调用 AI 对话生成服务
BAILIAN_API_KEY=your-api-key-here

# 百炼平台 API 地址（一般无需修改）
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===========================================
# OpenAI 兼容服务（可选）
# ===========================================

# 如果使用 OpenAI 或其他兼容服务，可配置以下变量
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ===========================================
# 数据库配置（可选）
# ===========================================

# PostgreSQL 数据库连接 URL
# 用于用户系统和游戏存档功能
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_game

# ===========================================
# 会话和安全配置
# ===========================================

# 会话密钥（用于加密会话数据）
# 生产环境必须配置为随机生成的长字符串
# 生成方式：openssl rand -base64 32
SESSION_SECRET=your-session-secret-here

# 应用 URL
# 生产环境必须配置为实际访问域名
# 用于生成正确的绝对 URL 和配置 CORS
APP_URL=http://localhost:3000

# ===========================================
# 监控和错误追踪（可选）
# ===========================================

# Sentry DSN
# 用于错误监控和性能追踪
# 获取地址：https://sentry.io/
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ===========================================
# 访问统计（可选）
# ===========================================

# Umami Analytics 配置
# 开源、隐私友好的网站访问统计
# 官方文档：https://umami.is/docs

# Umami Website ID（从 Umami 控制台获取）
# 注意：Vite 环境变量必须以 VITE_ 开头才能暴露给客户端
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Umami 脚本地址（可选，默认使用 Umami Cloud）
# 自托管时填写自己的服务器地址
# VITE_UMAMI_SRC=https://analytics.example.com/script.js

# 运行环境
# development | production | test
NODE_ENV=development

# ===========================================
# 服务端口（可选）
# ===========================================

# 应用监听端口，默认 3000
# PORT=3000